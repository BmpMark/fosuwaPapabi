{
  "include": [
    "client/src/**/*",
    "shared/**/*",
    "server/**/*"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "**/*.test.ts"
  ],
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/typescript/tsbuildinfo",

    /* Build Output */
    "outDir": "dist",
    "rootDir": ".",
    "noEmit": false,

    /* Language & Module */
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",

    /* Strictness */
    "strict": true,
    "skipLibCheck": true,

    /* Interop */
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,

    /* Frontend Support */
    "lib": ["esnext", "dom", "dom.iterable"],
    "jsx": "preserve",

    /* Paths */
    "baseUrl": ".",
    "types": ["node", "vite/client"],
    "paths": {
      "@/*": ["./client/src/*"],
      "@shared/*": ["./shared/*"]
    }
  }
}
