{
  "compilerOptions": {
    "baseUrl": ".",
    "types": ["node", "vite/client"],
    "paths": {
      "@shared/*": ["shared/*"]
    },
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "outDir": "../dist",
    "rootDir": ".",
    "strict": true,
    "lib": ["esnext", "dom", "dom.iterable"],
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "moduleResolution": "bundler",
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "incremental": true
  },
  "include": ["./**/*.ts", "../shared/**/*.ts", "client/src/**/*", "server/**/*"],
  "exclude": ["node_modules", "client/src/sw.ts"]
}



