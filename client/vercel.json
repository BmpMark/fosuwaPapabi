// {
//     "routes": [
//       { "src": "/(.*)", "dest": "/" }
//     ]
//   }
  
{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "../server/public" }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/server/public/$1" }
  ],
  "outputDirectory": "server/public"
}